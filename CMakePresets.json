{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_EXTENSIONS": "OFF",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_C_FLAGS": "-Wall -Wextra -Wpedantic -Werror"
            }
        },
        {
            "name": "debug",
            "inherits": "default",
            "displayName": "Debug",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS_DEBUG": "-g -O0",
                "CMAKE_C_FLAGS_DEBUG": "-g -O0"
            }
        },
        {
            "name": "release",
            "inherits": "default",
            "displayName": "Release",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS_RELEASE": "-O3",
                "CMAKE_C_FLAGS_RELEASE": "-O3"
            }
        },
        {
            "name": "clang-tidy",
            "inherits": "debug",
            "displayName": "debug+clang-tidy",
            "cacheVariables": {
                "CMAKE_CXX_CLANG_TIDY": {
                    "type": "STRING",
                    "value": "clang-tidy"
                }
            }
        },
        {
            "name": "asan",
            "inherits": "debug",
            "displayName": "debug+asan+ubsan",
            "binaryDir": "${sourceDir}/build/asan",
            "cacheVariables": {
                "CMAKE_CXX_FLAGS_DEBUG": "-g -O0 -fsanitize=address,undefined -fno-omit-frame-pointer",
                "CMAKE_C_FLAGS_DEBUG": "-g -O0 -fsanitize=address,undefined -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
                "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
            }
        },
        {
            "name": "coverage",
            "inherits": "debug",
            "displayName": "debug+coverage",
            "binaryDir": "${sourceDir}/build/coverage",
            "cacheVariables": {
                "CMAKE_CXX_FLAGS_DEBUG": "-g -O0 -fprofile-instr-generate -fcoverage-mapping",
                "CMAKE_C_FLAGS_DEBUG": "-g -O0 -fprofile-instr-generate -fcoverage-mapping",
                "CMAKE_EXE_LINKER_FLAGS": "-fprofile-instr-generate",
                "CMAKE_SHARED_LINKER_FLAGS": "-fprofile-instr-generate"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "clang-tidy",
            "configurePreset": "clang-tidy"
        },
        {
            "name": "asan",
            "configurePreset": "asan"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "release",
            "configurePreset": "release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "coverage",
            "configurePreset": "coverage",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
